//The repo already had a .env with real credentials including a summarizer 
//API key — that confirmed the summarize view calls a real external service and 
//made the error handling fix even more important. I created .env.example with 
//placeholder values so teammates know exactly what variables are needed without
// any real secrets being committed.

# Copy to .env and fill in real values — never commit .env

# Django secret key
DJANGO_SECRET_KEY=replace-me

# Set to False in production
DJANGO_DEBUG=False

# Postgres connection string
DATABASE_URL=postgres://notesy:password@db:5432/notesy

# Internal summarization service
SUMMARIZER_API_KEY=replace-me
SUMMARIZER_URL=replace-me

# Postgres container password
POSTGRES_PASSWORD=replace-me